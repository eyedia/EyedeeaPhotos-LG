# Optional — defaults to production API
VITE_API_BASE_URL=https://www.eyedeeaphotos.com/api/v1
VITE_ACTIVATE_URL=https://www.eyedeeaphotos.com/activate

# Simulator target for ares-launch -s <version>
WEBOS_SIM_VERSION=25

# webOS TV SDK root — npm scripts prepend CLI\bin to PATH (fixes PowerShell/Cursor terminals)
# LG_WEBOS_TV_SDK_HOME=E:\Tools\webOS_TV_SDK

# Source for icon generation (default: synced from EyedeeaPhotos-Cloud play-store asset)
# BRAND_ICON_PATH=E:\Work\EyedeeaPhotos-Cloud\apps\android\play-store-assets\graphics\eyedeea_photos_512x512.png
