{
  "name": "eyedeea-photos-lg",
  "version": "1.0.0",
  "description": "Eyedeea Photos view-only app for LG webOS TV",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "icons": "node scripts/generate-icons.js",
    "submission-assets": "node scripts/generate-submission-assets.js",
    "verify:env": "powershell -ExecutionPolicy Bypass -File scripts/verify-dev-env.ps1",
    "stage:webos": "powershell -ExecutionPolicy Bypass -File scripts/stage-webos.ps1 -SkipInstall",
    "sim": "powershell -ExecutionPolicy Bypass -File scripts/launch-simulator.ps1",
    "sim:inspect": "powershell -ExecutionPolicy Bypass -File scripts/inspect-simulator.ps1",
    "package:webos": "powershell -ExecutionPolicy Bypass -File scripts/build-ipk.ps1",
    "package:webos:sign": "powershell -ExecutionPolicy Bypass -File scripts/build-ipk.ps1 -Sign"
  },
  "dependencies": {
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.3",
    "sharp": "^0.35.2",
    "vite": "^8.1.0"
  },
  "author": "Eyedeea Tech",
  "license": "UNLICENSED"
}
